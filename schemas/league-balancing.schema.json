  "algorithmus": {
    "axis_geo": {
      "ablauf": [
        "1. Alle Teams in der Gruppe sammeln",
        "2. mobile = Teams mit lat+lon != 0; fixed = Rest",
        "3. slots[lid] = max(0, liga.target - fixed_count[lid])",
        "4. mobile nach minimaler Distanz zum nächsten Zentrum sortieren (stärkste Präferenz zuerst)",
        "5. Jedes Team → nächstes Zentrum mit freiem Slot zuweisen",
        "6. Kein freier Slot gefunden → Team bleibt in aktueller Liga"
      ],
      "distanzformel": "sqrt( (team.lat - center.lat)² + ((team.lon - center.lon) × 0.7)² )",
      "lon_faktor_0.7": "Längengrade sind in Mitteleuropa (~50°N) ~70% kürzer als Breitengrade",
      "zentroide_anpassen": "Wenn Liga X systematisch zu viele/wenige Teams bekommt → Zentroid verschieben. Faustformel: 0.1° ≈ 11km (lat) bzw. 7.5km (lon)."
    },
    "axis_lat": {
      "ablauf": "mobile-Teams nach lat DESC sortieren, gleichmäßig auf Ligen aufteilen via Math.ceil",
      "verwendung": "Bayernliga (5-13/14), Berlin-Staffeln (7-8/9)"
    },
    "sibling_exclusion": {
      "beschreibung": "balanceDynamicGroups baut siblingCovered-Set aus allen SIBLING_GROUPS-IDs und überspringt diese im auto-Grouping",
      "folge": "Kein Doppel-Processing; auto-Grouping trifft praktisch keine Ligen mehr (alle sinnvollen Paare sind in SIBLING_GROUPS)"
    }
  }
}
